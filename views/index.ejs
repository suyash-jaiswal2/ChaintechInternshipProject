<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Task Manager</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/style.css"/>
</head>
<body>
  <div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="fw-bold">📝 Task Manager</h1>
      <a href="/tasks/new" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Task
      </a>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <% if (tasks.length === 0) { %>
      <div class="text-center text-muted py-5">
        <i class="bi bi-clipboard-x" style="font-size: 3rem;"></i>
        <p class="mt-3">No tasks yet. Click "New Task" to get started!</p>
      </div>
    <% } else { %>
      <div class="row g-3">
        <% tasks.forEach(task => { %>
          <div class="col-12">
            <div class="card shadow-sm task-card <%= task.completed ? 'completed-task' : '' %>">
              <div class="card-body d-flex justify-content-between align-items-start">

                <div>
                  <h5 class="card-title mb-1 <%= task.completed ? 'text-decoration-line-through text-muted' : '' %>">
                    <%= task.title %>
                    <% if (task.completed) { %>
                      <span class="badge bg-success ms-2">Done</span>
                    <% } %>
                    <% if (task.category) { %>
                      <span class="badge bg-secondary ms-1"><%= task.category %></span>
                    <% } %>
                  </h5>
                  <% if (task.description) { %>
                    <p class="text-muted mb-1"><%= task.description %></p>
                  <% } %>
                  <% if (task.dueDate) { %>
                    <small class="text-muted">
                      <i class="bi bi-calendar3"></i>
                      Due: <%= new Date(task.dueDate).toDateString() %>
                    </small>
                  <% } %>
                </div>

                <div class="d-flex gap-2 flex-shrink-0 ms-3">
                  <% if (!task.completed) { %>
                    <form action="/tasks/<%= task._id %>/complete?_method=PUT" method="POST">
                      <button class="btn btn-success btn-sm" title="Mark Complete">
                        <i class="bi bi-check-lg"></i>
                      </button>
                    </form>
                  <% } %>

                  <a href="/tasks/<%= task._id %>/edit" class="btn btn-warning btn-sm" title="Edit">
                    <i class="bi bi-pencil"></i>
                  </a>

                  <form action="/tasks/<%= task._id %>?_method=DELETE" method="POST"
                        onsubmit="return confirm('Delete this task?')">
                    <button class="btn btn-danger btn-sm" title="Delete">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                </div>

              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>